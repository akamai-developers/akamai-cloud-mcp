{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.akamai-developers/akamai-cloud-mcp",
  "description": "Read-only MCP server for Akamai Cloud (Linode): inventory, pricing, and account limits.",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/akamai-developers/akamai-cloud-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registry_type": "pypi",
      "identifier": "akamai-cloud-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "name": "LINODE_TOKEN",
          "description": "Read-only-scoped Linode personal access token.",
          "is_required": true,
          "is_secret": true
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://your-deployment.example.com/mcp/"
    }
  ]
}
